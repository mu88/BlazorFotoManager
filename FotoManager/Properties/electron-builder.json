{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/refs/heads/master/packages/app-builder-lib/scheme.json",
  "appId": "${productName}.${version}",
  "productName": "FotoFlipper",
  "artifactName": "${productName}_${version}.${ext}",
  "compression": "maximum",
  "win": {
    "target": "portable"
  },
  "icon": "bin/assets/icon.ico",
  "files": [
    "**/*",
    "!wwwroot/font-awesome/js/**",
    "!wwwroot/font-awesome/less/**",
    "!wwwroot/font-awesome/scss/**",
    "!wwwroot/font-awesome/metadata/**",
    "!wwwroot/font-awesome/sprites/**",
    "!wwwroot/font-awesome/svgs/**",
    "!wwwroot/font-awesome/css/*.css",
    "wwwroot/font-awesome/css/all.min.css"
  ]
}